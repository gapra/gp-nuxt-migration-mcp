{
  "name": "@gapra/nuxt-migration-mcp",
  "version": "1.3.2",
  "description": "MCP Server for AI-assisted Nuxt 2/3 to Nuxt 3/4 migration — audits Options API, Vuex, asyncData, ESM compatibility, and generates Pinia/Composable code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nuxt-migration-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/add-shebang.js",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:hooks": "vitest run hooks",
    "mcp:analysis": "node dist/mcp_servers/analysis_server.js",
    "mcp:generator": "node dist/mcp_servers/generator_server.js",
    "mcp:orchestrator": "node dist/mcp_servers/orchestrator_server.js",
    "mcp:dev:analysis": "tsx watch src/mcp_servers/analysis_server.ts",
    "mcp:dev:generator": "tsx watch src/mcp_servers/generator_server.ts",
    "mcp:dev:orchestrator": "tsx watch src/mcp_servers/orchestrator_server.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "nuxt",
    "nuxt2",
    "nuxt3",
    "nuxt4",
    "nuxt-migration",
    "nuxt2-to-nuxt3",
    "nuxt3-to-nuxt4",
    "migration",
    "vue",
    "vue2",
    "vue3",
    "vuex",
    "pinia",
    "composition-api",
    "options-api",
    "composable",
    "typescript",
    "esm",
    "tailwindcss",
    "codemod",
    "ai",
    "claude"
  ],
  "author": "Gapra (gapraart@gmail.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gapra/gp-nuxt-migration-mcp.git"
  },
  "homepage": "https://github.com/gapra/gp-nuxt-migration-mcp#readme",
  "bugs": {
    "url": "https://github.com/gapra/gp-nuxt-migration-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^11.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
