# Nuxt Migration MCP Configuration

# REQUIRED: Path to your Nuxt 2 source codebase
MIGRATION_SOURCE_PATH=/path/to/your/nuxt2/project

# OPTIONAL: Path to your Nuxt 3/4 target codebase (defaults to current directory)
MIGRATION_TARGET_PATH=/path/to/your/nuxt4/project

# Example configuration:
# MIGRATION_SOURCE_PATH=/Users/mekari/Projects/my-nuxt2-app
# MIGRATION_TARGET_PATH=/Users/mekari/Projects/my-nuxt4-app
